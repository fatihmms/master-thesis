# =====================================================================
# Environment template for the Slurm run scripts (scripts/*.sh).
#
# Copy this to `.env` at the repo root ON EACH ACCOUNT and fill in the
# real values. `.env` is gitignored; `.env.example` is committed.
#
#   cp .env.example .env
#   # then edit .env
#
# The run scripts source this file via $SLURM_SUBMIT_DIR/.env, so always
# submit from the repo root:  cd <repo> && sbatch scripts/<name>.sh
# =====================================================================

# Absolute path to the repo root on THIS machine/account.
# Differs per account (the ka_xxxxxx part is account-specific).
export PROJECT_ROOT=/home/ka/ka_ksri/ka_xxxxxx/master-thesis

# Hugging Face access token (gated models: Llama-3.1, Mistral-7B-v0.3).
# Create one at https://huggingface.co/settings/tokens  (read scope).
export HF_TOKEN=hf_replace_with_your_real_token